# Odds API
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# Database (assembled into postgresql+asyncpg://user:pass@host:port/dbname)
BASESTAR_ADDRESS=localhost
DB_NAME=odds_engine
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432

# Redis (assembled into redis://user:pass@host:port/db)
# CACHE_USER can be left empty if your Redis instance does not require a username
CACHE_USER=
CACHE_PASSWORD=your_redis_password_here
CACHE_PORT=6379
CACHE_DB=0

# Auth
# Shared secret for X-API-Key header (REST) and api_key query param (WebSocket)
API_SECRET_KEY=your_shared_secret_here

# Budget
# Total credits available per calendar month (free tier = 500)
MONTHLY_CREDIT_LIMIT=500
# Conservative daily target: 500 / 31 ~ 16
DAILY_CREDIT_TARGET=16

# Scheduler
SCHEDULER_ENABLED=true
# How often to re-fetch odds for pre-match events (minutes)
PRE_MATCH_INTERVAL_MINUTES=60
# How often to re-fetch odds for live events (minutes)
LIVE_INTERVAL_MINUTES=10
# How often to refresh the active sports list from /sports (minutes)
SPORTS_DISCOVERY_INTERVAL_MINUTES=60

# Logging
# Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Format: json (production) | console (development)
LOG_FORMAT=json
